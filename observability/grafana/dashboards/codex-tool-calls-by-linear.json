  "panels": [
    {
      "datasource": {
        "type": "victoriametrics-logs-datasource",
        "uid": "victorialogs"
      },
      "description": "Total tool calls, unique tool names, and unique runs (traces) for the selected Linear issue.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 5,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "percentChangeColorMode": "standard",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showPercentChange": false,
        "textMode": "auto",
        "wideLayout": true
      },
      "pluginVersion": "13.0.0",
      "targets": [
        {
          "datasource": {
            "type": "victoriametrics-logs-datasource",
            "uid": "victorialogs"
          },
          "expr": "linear.issue.identifier:=\"$linear_issue\" trace_id:~\"$trace_id\" _msg:codex.tool_result tool_name:~\"$tool_name\" | stats count() as tool_calls, count_uniq(tool_name) as unique_tools, count_uniq(trace_id) as unique_runs",
          "queryType": "stats",
          "refId": "A"
        }
      ],
      "title": "Selected Issue Summary",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "victoriametrics-logs-datasource",
        "uid": "victorialogs"
      },
      "description": "apply_patch-only summary for the selected Linear issue. No data means this issue has no apply_patch calls.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Tool Calls Before First Write"
            },
            "properties": [
              {
                "id": "decimals",
                "value": 0
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Avg Tools Before Write"
            },
            "properties": [
              {
                "id": "decimals",
                "value": 1
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Num Writes"
            },
            "properties": [
              {
                "id": "decimals",
                "value": 0
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 5,
        "w": 16,
        "x": 8,
        "y": 0
      },
      "id": 7,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "percentChangeColorMode": "standard",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showPercentChange": false,
        "textMode": "auto",
        "wideLayout": true
      },
      "pluginVersion": "13.0.0",
      "targets": [
        {
          "datasource": {
            "type": "victoriametrics-logs-datasource",
            "uid": "victorialogs"
          },
          "expr": "linear.issue.identifier:=\"$linear_issue\" trace_id:~\"$trace_id\" _msg:codex.tool_result | sort by (_time asc) rank as call_number | filter tool_name:=apply_patch | math (call_number - 1) as tools_before_write | stats min(tools_before_write) as tool_calls_before_first_write, avg(tools_before_write) as avg_tools_before_write, count() as num_writes",
          "queryType": "stats",
          "refId": "A"
        }
      ],
      "title": "Write Summary",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "indexByName": {
              "avg_tools_before_write": 1,
              "num_writes": 2,
              "tool_calls_before_first_write": 0
            },
            "renameByName": {
              "avg_tools_before_write": "Avg Tools Before Write",
              "num_writes": "Num Writes",
              "tool_calls_before_first_write": "Tool Calls Before First Write"
            }
          }
        }
      ],
      "type": "stat"
    },
    {
      "datasource": {
        "type": "victoriametrics-logs-datasource",
