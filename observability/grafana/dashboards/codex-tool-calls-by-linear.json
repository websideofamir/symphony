        "showPercentChange": false,
        "textMode": "auto",
        "wideLayout": true
      },
      "pluginVersion": "13.0.0",
      "targets": [
        {
          "datasource": {
            "type": "victoriametrics-logs-datasource",
            "uid": "victorialogs"
          },
          "expr": "linear.issue.identifier:=\"$linear_issue\" trace_id:~\"$trace_id\" _msg:codex.sse_event event.kind:=\"response.completed\" input_token_count:* | math input_token_count*5/1000000 + output_token_count*30/1000000 + cached_token_count*0.5/1000000 as row_cost | stats sum(input_token_count) as total_input_tokens, sum(output_token_count) as total_output_tokens, sum(cached_token_count) as total_cached_tokens, sum(row_cost) as total_cost_usd",
          "queryType": "stats",
          "refId": "A"
        }
      ],
      "title": "Token Totals & Est. Cost",
      "type": "stat"
    },
