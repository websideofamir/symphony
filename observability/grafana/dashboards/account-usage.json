    {
      "datasource": {
        "type": "datasource",
        "uid": "-- Mixed --"
      },
      "description": "Per-account token usage across Codex and Claude. Codex rows come from VictoriaLogs codex.sse_event entries; Claude rows come from VictoriaLogs api_request entries.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "inspect": false
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "input_tokens"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 130
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "cache_read_tokens"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 150
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "cache_creation_tokens"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 165
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "output_tokens"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 135
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "total_tokens"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 135
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 11,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "id": 5,
      "options": {
        "cellHeight": "sm",
        "footer": {
          "countRows": false,
          "fields": "",
          "reducer": [
            "sum"
          ],
          "show": false
        },
        "showHeader": true
      },
      "targets": [
        {
          "datasource": {
            "type": "victoriametrics-logs-datasource",
            "uid": "victorialogs"
          },
          "expr": "event.name:codex.sse_event input_token_count:~\".+\" symphony.backend:~\"${backend:regex}\" symphony.account.id:~\".+\" symphony.account.id:~\"${account_id:regex}\" user.email:~\".+\" user.email:~\"${account_email:regex}\" | copy symphony.backend as backend | copy symphony.account.id as account_id | copy user.email as account_email | format \"input_tokens\" as token_type | stats by (backend, account_id, account_email, token_type) sum(input_token_count) as value",
          "queryType": "stats",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "victoriametrics-logs-datasource",
            "uid": "victorialogs"
          },
          "expr": "event.name:codex.sse_event cached_token_count:~\".+\" symphony.backend:~\"${backend:regex}\" symphony.account.id:~\".+\" symphony.account.id:~\"${account_id:regex}\" user.email:~\".+\" user.email:~\"${account_email:regex}\" | copy symphony.backend as backend | copy symphony.account.id as account_id | copy user.email as account_email | format \"cache_read_tokens\" as token_type | stats by (backend, account_id, account_email, token_type) sum(cached_token_count) as value",
          "queryType": "stats",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "victoriametrics-logs-datasource",
            "uid": "victorialogs"
          },
          "expr": "event.name:codex.sse_event input_token_count:~\".+\" symphony.backend:~\"${backend:regex}\" symphony.account.id:~\".+\" symphony.account.id:~\"${account_id:regex}\" user.email:~\".+\" user.email:~\"${account_email:regex}\" | copy symphony.backend as backend | copy symphony.account.id as account_id | copy user.email as account_email | format \"cache_creation_tokens\" as token_type | stats by (backend, account_id, account_email, token_type) count() as samples | math (0) as value | fields backend, account_id, account_email, token_type, value",
          "queryType": "stats",
          "refId": "C"
        },
        {
          "datasource": {
            "type": "victoriametrics-logs-datasource",
            "uid": "victorialogs"
          },
          "expr": "event.name:codex.sse_event output_token_count:~\".+\" symphony.backend:~\"${backend:regex}\" symphony.account.id:~\".+\" symphony.account.id:~\"${account_id:regex}\" user.email:~\".+\" user.email:~\"${account_email:regex}\" | copy symphony.backend as backend | copy symphony.account.id as account_id | copy user.email as account_email | format \"output_tokens\" as token_type | stats by (backend, account_id, account_email, token_type) sum(output_token_count) as value",
          "queryType": "stats",
          "refId": "D"
        },
        {
          "datasource": {
            "type": "victoriametrics-logs-datasource",
            "uid": "victorialogs"
          },
          "expr": "event.name:codex.sse_event input_token_count:~\".+\" output_token_count:~\".+\" symphony.backend:~\"${backend:regex}\" symphony.account.id:~\".+\" symphony.account.id:~\"${account_id:regex}\" user.email:~\".+\" user.email:~\"${account_email:regex}\" | copy symphony.backend as backend | copy symphony.account.id as account_id | copy user.email as account_email | format \"total_tokens\" as token_type | stats by (backend, account_id, account_email, token_type) sum(input_token_count) as input_tokens, sum(output_token_count) as output_tokens | math (input_tokens + output_tokens) as value | fields backend, account_id, account_email, token_type, value",
          "queryType": "stats",
          "refId": "E"
        },
        {
          "datasource": {
            "type": "victoriametrics-logs-datasource",
            "uid": "victorialogs"
          },
          "expr": "_msg:=api_request input_tokens:~\".+\" symphony.backend:\"claude\" symphony.backend:~\"${backend:regex}\" symphony.account.id:~\".+\" symphony.account.id:~\"${account_id:regex}\" user.email:~\".+\" user.email:~\"${account_email:regex}\" | copy symphony.backend as backend | copy symphony.account.id as account_id | copy user.email as account_email | format \"input_tokens\" as token_type | stats by (backend, account_id, account_email, token_type) sum(input_tokens) as value",
          "queryType": "stats",
          "refId": "F"
        },
        {
          "datasource": {
            "type": "victoriametrics-logs-datasource",
            "uid": "victorialogs"
          },
          "expr": "_msg:=api_request cache_read_tokens:~\".+\" symphony.backend:\"claude\" symphony.backend:~\"${backend:regex}\" symphony.account.id:~\".+\" symphony.account.id:~\"${account_id:regex}\" user.email:~\".+\" user.email:~\"${account_email:regex}\" | copy symphony.backend as backend | copy symphony.account.id as account_id | copy user.email as account_email | format \"cache_read_tokens\" as token_type | stats by (backend, account_id, account_email, token_type) sum(cache_read_tokens) as value",
          "queryType": "stats",
          "refId": "G"
        },
        {
          "datasource": {
            "type": "victoriametrics-logs-datasource",
            "uid": "victorialogs"
          },
          "expr": "_msg:=api_request cache_creation_tokens:~\".+\" symphony.backend:\"claude\" symphony.backend:~\"${backend:regex}\" symphony.account.id:~\".+\" symphony.account.id:~\"${account_id:regex}\" user.email:~\".+\" user.email:~\"${account_email:regex}\" | copy symphony.backend as backend | copy symphony.account.id as account_id | copy user.email as account_email | format \"cache_creation_tokens\" as token_type | stats by (backend, account_id, account_email, token_type) sum(cache_creation_tokens) as value",
          "queryType": "stats",
          "refId": "H"
        },
        {
          "datasource": {
            "type": "victoriametrics-logs-datasource",
            "uid": "victorialogs"
          },
          "expr": "_msg:=api_request output_tokens:~\".+\" symphony.backend:\"claude\" symphony.backend:~\"${backend:regex}\" symphony.account.id:~\".+\" symphony.account.id:~\"${account_id:regex}\" user.email:~\".+\" user.email:~\"${account_email:regex}\" | copy symphony.backend as backend | copy symphony.account.id as account_id | copy user.email as account_email | format \"output_tokens\" as token_type | stats by (backend, account_id, account_email, token_type) sum(output_tokens) as value",
          "queryType": "stats",
          "refId": "I"
        },
        {
          "datasource": {
            "type": "victoriametrics-logs-datasource",
            "uid": "victorialogs"
          },
          "expr": "_msg:=api_request input_tokens:~\".+\" output_tokens:~\".+\" symphony.backend:\"claude\" symphony.backend:~\"${backend:regex}\" symphony.account.id:~\".+\" symphony.account.id:~\"${account_id:regex}\" user.email:~\".+\" user.email:~\"${account_email:regex}\" | copy symphony.backend as backend | copy symphony.account.id as account_id | copy user.email as account_email | format \"total_tokens\" as token_type | stats by (backend, account_id, account_email, token_type) sum(input_tokens) as input_tokens, sum(output_tokens) as output_tokens | math (input_tokens + output_tokens) as value | fields backend, account_id, account_email, token_type, value",
          "queryType": "stats",
          "refId": "J"
        }
      ],
      "title": "Per-Account Token Usage",
      "transformations": [
        {
          "id": "labelsToFields",
          "options": {
            "mode": "columns",
            "valueLabel": "token_type"
          }
        },
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Value": true,
              "__name__": true
            },
            "indexByName": {
              "account_email": 2,
              "account_id": 1,
              "backend": 0,
              "cache_creation_tokens": 5,
              "cache_read_tokens": 4,
              "input_tokens": 3,
              "output_tokens": 6,
              "total_tokens": 7
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": {},
            "sort": [
              {
                "desc": true,
                "field": "total_tokens"
              }
            ]
          }
        }
      ],
      "type": "table"
    },
    {
      "datasource": {
        "type": "victoriametrics-metrics-datasource",
        "uid": "victoriametrics"
      },
      "description": "Current session and weekly quota state from Symphony's /metrics endpoint, merged with current account state.",
      "fieldConfig": {
        "defaults": {
          "custom": {
