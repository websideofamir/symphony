        "showHeader": true
      },
      "targets": [
        {
          "datasource": {
            "type": "victoriametrics-metrics-datasource",
            "uid": "victoriametrics"
          },
          "expr": "label_set(last_over_time(symphony_account_rate_limit_used{backend=~\"${backend:regex}\",account_id=~\"${account_id:regex}\",account_email=~\"${account_email:regex}\"}[10m]), \"__name__\", \"rate_limit\", \"measure\", \"used\") or label_set(last_over_time(symphony_account_rate_limit_limit{backend=~\"${backend:regex}\",account_id=~\"${account_id:regex}\",account_email=~\"${account_email:regex}\"}[10m]), \"__name__\", \"rate_limit\", \"measure\", \"limit\") or label_set(last_over_time(symphony_account_rate_limit_remaining{backend=~\"${backend:regex}\",account_id=~\"${account_id:regex}\",account_email=~\"${account_email:regex}\"}[10m]), \"__name__\", \"rate_limit\", \"measure\", \"remaining\") or label_set(last_over_time(symphony_account_rate_limit_usage_percent{backend=~\"${backend:regex}\",account_id=~\"${account_id:regex}\",account_email=~\"${account_email:regex}\"}[10m]), \"__name__\", \"rate_limit\", \"measure\", \"usage_percent\") or label_set(1000 * last_over_time(symphony_account_rate_limit_reset_timestamp_seconds{backend=~\"${backend:regex}\",account_id=~\"${account_id:regex}\",account_email=~\"${account_email:regex}\"}[10m]), \"__name__\", \"rate_limit\", \"measure\", \"reset_at\")",
          "instant": true,
          "refId": "A"
        },
        {
          "datasource": {
            "type": "victoriametrics-metrics-datasource",
            "uid": "victoriametrics"
          },
          "expr": "last_over_time(symphony_account_state_info{backend=~\"${backend:regex}\",account_id=~\"${account_id:regex}\",account_email=~\"${account_email:regex}\"}[10m])",
          "instant": true,
          "refId": "B"
        }
      ],
      "title": "Current Limit Used",
      "transformations": [
        {
          "id": "labelsToFields",
          "options": {
            "mode": "columns",
            "valueLabel": "measure"
          }
        },
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Value": true,
              "__name__": true
            },
            "indexByName": {
              "account_email": 2,
              "account_id": 1,
              "backend": 0,
              "bucket": 6,
              "credential_kind": 4,
              "limit": 8,
              "limit_id": 5,
              "remaining": 10,
              "reset_at": 12,
              "state": 3,
              "usage_percent": 11,
              "used": 7
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": {},
            "sort": [
              {
                "desc": true,
                "field": "usage_percent"
              }
            ]
          }
        }
      ],
      "type": "table"
    },
    {
      "datasource": {
        "type": "victoriametrics-metrics-datasource",
        "uid": "victoriametrics"
      },
      "description": "Weekly billing-cycle rows aligned to each account reset boundary. Closed rows come from usage_periods.csv; active rows come from live account state.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "inspect": false
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "usage_percent"
            },
            "properties": [
              {
                "id": "unit",
                "value": "percent"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "period_started_at"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 210
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "reset_at"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 210
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 26
      },
      "id": 7,
      "options": {
        "cellHeight": "sm",
        "footer": {
          "countRows": false,
          "fields": "",
          "reducer": [
            "sum"
          ],
          "show": false
        },
        "showHeader": true
      },
      "targets": [
        {
          "datasource": {
            "type": "victoriametrics-metrics-datasource",
            "uid": "victoriametrics"
          },
