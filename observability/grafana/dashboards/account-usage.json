  "panels": [
    {
      "datasource": {
        "type": "victoriametrics-metrics-datasource",
        "uid": "victoriametrics"
      },
      "description": "Accounts currently marked limited or exhausted in Symphony account state.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              },
              {
                "color": "red",
                "value": 3
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "datasource": {
            "type": "victoriametrics-metrics-datasource",
            "uid": "victoriametrics"
          },
          "expr": "count(last_over_time(symphony_account_state_info{backend=~\"${backend:regex}\",account_id=~\"${account_id:regex}\",account_email=~\"${account_email:regex}\",state=~\"limited|exhausted\"}[10m]))",
          "instant": true,
          "legendFormat": "limited_accounts",
          "refId": "A"
        }
      ],
      "title": "Limited / Exhausted",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "victoriametrics-metrics-datasource",
        "uid": "victoriametrics"
      },
      "description": "Earliest weekly reset across the currently filtered accounts.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "dateTimeAsIso"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "datasource": {
            "type": "victoriametrics-metrics-datasource",
            "uid": "victoriametrics"
          },
          "expr": "min(1000 * last_over_time(symphony_account_rate_limit_reset_timestamp_seconds{backend=~\"${backend:regex}\",account_id=~\"${account_id:regex}\",account_email=~\"${account_email:regex}\",bucket=\"weekly\"}[10m]))",
          "instant": true,
          "legendFormat": "next_weekly_reset",
          "refId": "A"
        }
      ],
      "title": "Next Weekly Reset",
      "type": "stat"
    },
    {
      "datasource": {
