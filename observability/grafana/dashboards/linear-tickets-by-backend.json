{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": {
        "type": "victoriametrics-logs-datasource",
        "uid": "victorialogs"
      },
      "description": "Unique Linear ticket identifiers seen in tool_result events from either backend, scoped to the selected team prefix(es) and time range.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 5,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "percentChangeColorMode": "standard",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showPercentChange": false,
        "textMode": "auto",
        "wideLayout": true
      },
      "pluginVersion": "13.0.0",
      "targets": [
        {
          "datasource": {
            "type": "victoriametrics-logs-datasource",
            "uid": "victorialogs"
          },
          "expr": "(_msg:claude_code.tool_result OR _msg:codex.tool_result) linear.issue.identifier:~\"^($team_prefix)-.*\" | stats count_uniq(linear.issue.identifier) as unique_tickets",
          "queryType": "stats",
          "refId": "A"
        }
      ],
      "title": "Unique Tickets",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "victoriametrics-logs-datasource",
        "uid": "victorialogs"
      },
      "description": "Unique tickets seen per backend. A ticket run on both backends is counted once for each.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              }
            ]
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "claude"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "orange",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "codex"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "blue",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 5,
        "w": 16,
        "x": 8,
        "y": 0
      },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "percentChangeColorMode": "standard",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showPercentChange": false,
        "textMode": "value_and_name",
        "wideLayout": true
      },
      "pluginVersion": "13.0.0",
      "targets": [
        {
          "datasource": {
            "type": "victoriametrics-logs-datasource",
            "uid": "victorialogs"
          },
          "expr": "_msg:claude_code.tool_result linear.issue.identifier:~\"^($team_prefix)-.*\" | stats count_uniq(linear.issue.identifier) as claude",
          "queryType": "stats",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "victoriametrics-logs-datasource",
            "uid": "victorialogs"
          },
          "expr": "_msg:codex.tool_result linear.issue.identifier:~\"^($team_prefix)-.*\" | stats count_uniq(linear.issue.identifier) as codex",
          "queryType": "stats",
          "refId": "B"
        }
      ],
      "title": "Tickets by Backend",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "victoriametrics-logs-datasource",
        "uid": "victorialogs"
      },
      "description": "One row per API request (Claude api_request) or response.completed event (Codex), showing timestamp, Linear ticket, backend, and token usage. Filter by team prefix (ANA, SYM, ...) using the dropdown above.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "filterable": true,
            "footer": {
              "reducers": []
            },
            "inspect": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Started"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 210
              },
              {
                "id": "unit",
                "value": "dateTimeAsIso"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Last Seen"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 210
              },
              {
                "id": "unit",
                "value": "dateTimeAsIso"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Events"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 100
              },
              {
                "id": "unit",
                "value": "short"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Linear Ticket"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 140
              },
              {
                "id": "links",
                "value": [
                  {
                    "targetBlank": true,
                    "title": "Open in Linear",
                    "url": "https://linear.app/issue/${__value.raw}"
                  }
                ]
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Backend"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 100
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "claude": {
                        "color": "orange",
                        "index": 0
                      },
                      "codex": {
                        "color": "blue",
                        "index": 1
                      }
                    }
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 20,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "id": 3,
      "options": {
        "cellHeight": "sm",
        "showHeader": true,
        "sortBy": [
          {
            "desc": true,
            "displayName": "Started"
          }
        ]
      },
      "pluginVersion": "13.0.0",
      "targets": [
        {
          "datasource": {
            "type": "victoriametrics-logs-datasource",
            "uid": "victorialogs"
          },
          "expr": "_msg:claude_code.tool_result linear.issue.identifier:~\"^($team_prefix)-.*\" | format \"claude\" as backend | stats by (linear.issue.identifier, backend) min(_time) as started, max(_time) as last_seen, count() as events",
          "queryType": "instant",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "victoriametrics-logs-datasource",
            "uid": "victorialogs"
          },
          "expr": "_msg:codex.tool_result linear.issue.identifier:~\"^($team_prefix)-.*\" | format \"codex\" as backend | stats by (linear.issue.identifier, backend) min(_time) as started, max(_time) as last_seen, count() as events",
          "queryType": "instant",
          "refId": "B"
        }
      ],
      "title": "Linear Ticket Activity by Backend",
      "transformations": [
        {
          "id": "extractFields",
          "options": {
            "format": "json",
            "keepTime": false,
            "replace": true,
            "source": "labels"
          }
        },
        {
          "id": "convertFieldType",
          "options": {
            "conversions": [
              {
                "destinationType": "time",
                "targetField": "started"
              },
              {
                "destinationType": "time",
                "targetField": "last_seen"
              },
              {
                "destinationType": "number",
                "targetField": "events"
              }
            ]
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Line": true,
              "labels": true
            },
            "indexByName": {
              "started": 0,
              "linear.issue.identifier": 1,
              "backend": 2,
              "events": 3,
              "last_seen": 4
            },
            "renameByName": {
              "started": "Started",
              "linear.issue.identifier": "Linear Ticket",
              "backend": "Backend",
              "events": "Events",
              "last_seen": "Last Seen"
            }
          }
        },
        {
          "id": "merge"
        },
        {
          "id": "sortBy",
          "options": {
            "fields": {},
            "sort": [
              {
                "desc": true,
                "field": "Started"
              }
            ]
          }
        }
      ],
      "type": "table"
    }
  ],
  "preload": false,
  "refresh": "30s",
  "schemaVersion": 42,
  "tags": ["linear", "backend", "claude", "codex"],
  "templating": {
    "list": [
      {
        "allValue": "[A-Z]+",
        "allowCustomValue": true,
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "datasource": {
          "type": "victoriametrics-logs-datasource",
          "uid": "victorialogs"
        },
        "description": "Three-letter (or longer) Linear team prefix. Extracted from linear.issue.identifier values seen in tool_result events.",
        "hide": 0,
        "includeAll": true,
        "label": "Team Prefix",
        "multi": true,
        "name": "team_prefix",
        "options": [],
        "query": {
          "field": "linear.issue.identifier",
          "limit": 1000,
          "query": "(_msg:claude_code.tool_result OR _msg:codex.tool_result) linear.issue.identifier:*",
          "refId": "VictoriaLogsVariableQueryEditor-VariableQuery",
          "type": "fieldValue"
        },
        "refresh": 2,
        "regex": "/^([A-Z]+)-.*/",
        "regexApplyTo": "value",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["10s", "30s", "1m", "5m", "15m"]
  },
  "timezone": "browser",
  "title": "Linear Tickets by Backend",
  "uid": "linear-tickets-by-backend",
  "version": 1
}
