        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "footer": {
              "reducers": []
            },
            "inspect": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
